# Local secrets for the Cloudflare Pages Functions (the OAuth backend).
# Copy to `.dev.vars` (gitignored) and fill in. `wrangler pages dev` loads these automatically.
#
# In production these are NOT read from here — set them on the Cloudflare Pages project under
# Settings → Variables and Secrets (see README "Deploying to Cloudflare Pages").
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: getrecall.ai (Recall) API key for the "Summary" tab. Grants read access to your whole
# Recall knowledge base, so it lives only here / in the Pages project secrets — never in the browser.
# Get one from Recall → Settings → API & MCP. Leave blank to hide the Summary tab.
RECALL_API_KEY=
