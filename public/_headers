# Cloudflare Pages / Netlify response headers (served at the site root).
# This is the header-based CSP — stronger than the <meta> tag in index.html because it can
# also set frame-ancestors (clickjacking). Keep it in sync with that meta tag.
#
# All YouTube traffic now goes through same-origin Functions (/api/youtube/*, /auth/*), so
# connect-src is just 'self'. The API key is used server-side (no HTTP-referrer restriction), so
# we can use the strictest Referrer-Policy.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://www.youtube.com; connect-src 'self'; frame-src https://www.youtube-nocookie.com; img-src 'self' data: https://*.ytimg.com https://*.ggpht.com; style-src 'self' 'unsafe-inline'; base-uri 'self'; object-src 'none'; form-action 'self'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
